# ⚙️ Configuración de Variables de Entorno - ParkiFy Frontend

# =============================================================================
# 🌐 BACKEND API CONFIGURATION
# =============================================================================

# URL del backend API (sin /api al final, se agrega automáticamente en axios.ts)
# Para desarrollo local:
# VITE_API_URL=http://localhost:3000/api

# Para producción (Render u otro hosting):
VITE_API_URL=https://parkify-back.onrender.com/api/v1

# =============================================================================
# 🔌 WEBSOCKET CONFIGURATION
# =============================================================================

# URL del servidor WebSocket para actualizaciones en tiempo real
# IMPORTANTE: NO incluir /socket.io al final (se agrega automáticamente)
# Para desarrollo local:
# VITE_WEBSOCKET_URL=http://localhost:3000

# Para producción (Render u otro hosting):
VITE_WEBSOCKET_URL=https://parkify-back.onrender.com

# =============================================================================
# 🗺️ ROUTER MODE
# =============================================================================

# Modo de enrutamiento de React Router
# - "hash": Usa HashRouter (#/mapa) - Recomendado para GitHub Pages o hosting estático
# - "browser": Usa BrowserRouter (/mapa) - Requiere configuración del servidor
VITE_ROUTER_MODE=hash

# =============================================================================
# 📸 CLOUDINARY CONFIGURATION (Opcional - para subir imágenes)
# =============================================================================

# URL de Cloudinary para subir imágenes de estacionamientos
# Ejemplo: https://api.cloudinary.com/v1_1/tu-cloud-name/image/upload
VITE_CLOUDINARY_URL=https://api.cloudinary.com/v1_1/TU_CLOUD_NAME/image/upload

# Preset de subida de Cloudinary (configurado en tu cuenta de Cloudinary)
VITE_CLOUDINARY_UPLOAD_PRESET=tu_upload_preset

# =============================================================================
# 📝 NOTAS IMPORTANTES
# =============================================================================

# 1. Este archivo (env.template) es solo una plantilla
# 2. Copia este archivo y renómbralo a .env
# 3. Reemplaza los valores con tu configuración real
# 4. NUNCA subas el archivo .env a Git (ya está en .gitignore)
# 5. Todas las variables deben comenzar con VITE_ para que Vite las reconozca
# 6. Reinicia el servidor de desarrollo después de modificar el .env

# =============================================================================
# 🚀 PASOS PARA CONFIGURAR
# =============================================================================

# 1. Copia este archivo:
#    cp env.template .env     (Linux/Mac)
#    copy env.template .env   (Windows)
#
# 2. Edita .env y reemplaza:
#    - tu-backend-en-render.onrender.com con tu URL real de Render
#    - TU_CLOUD_NAME con tu nombre de Cloudinary
#    - tu_upload_preset con tu preset de Cloudinary
#
# 3. Reinicia el servidor:
#    npm run dev

